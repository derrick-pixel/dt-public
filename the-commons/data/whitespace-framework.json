{
  "grid_size": "8x8",
  "research_date": "2026-04-22",
  "project": "The Commons",
  "notes": "8x8 overview. Segments span organiser type x scale x formality. Needs mix fees, escrow/trust, marketplace depth, SG localisation.",
  "canvas_dims": [
    "Low platform fee (%)",
    "Escrow by default",
    "2-sided vendor marketplace",
    "SG localisation (PayNow/GST)",
    "Brand trust / polish",
    "Creator tools depth",
    "Payment flexibility",
    "Community / virality"
  ],
  "us_scores_canvas": [4, 5, 5, 5, 4, 4, 4, 3],
  "us_scores_rationale": {
    "Low platform fee (%)": "Mid-tier fee (~6-8%) — not the cheapest (DIY/PayNow is 0%) but cheaper than Eventbrite's ~10%+",
    "Escrow by default": "Core differentiator — others pay-immediately or charge add-on for refund protection",
    "2-sided vendor marketplace": "Commons uniquely bundles event platform + freelance marketplace under one roof",
    "SG localisation (PayNow/GST)": "PayNow native, SGD-priced, GST-aware, IRAS-friendly",
    "Brand trust / polish": "Daiquiri/beach brand signals cultural not corporate; Elitez Group backing adds legitimacy",
    "Creator tools depth": "Mid — page builder + ticket types + marketplace. Less deep than Eventbrite/Ticketmaster but more purposeful",
    "Payment flexibility": "PayNow + cards + escrow. Lacks buy-now-pay-later.",
    "Community / virality": "Early — no discovery feed yet; organiser-driven traffic"
  },
  "segments": [
    { "id": "hobby_creator_sub100",    "label": "Hobby creator <100-seat",       "note": "Workshops, niche meetups, bake sales" },
    { "id": "pro_trainer_1k_plus",     "label": "Pro trainer 100-1000 seat",     "note": "Recurring courses, retreats, conferences" },
    { "id": "corporate_offsite",       "label": "Corporate offsite / retreat",   "note": "HR team running 20-100 ppl internal" },
    { "id": "fitness_wellness_chain",  "label": "Fitness / wellness chain",      "note": "Yoga, pilates, HIIT, multi-outlet" },
    { "id": "cultural_ngo_ticketed",   "label": "Cultural / NGO ticketed",       "note": "Heritage tours, NGO fundraisers" },
    { "id": "foodtour_local_guide",    "label": "Food tour / local guide",       "note": "Hawker walks, craft cocktails, drop-ins" },
    { "id": "one_off_private_event",   "label": "One-off private event",         "note": "Weddings, birthdays, dinner parties" },
    { "id": "regulated_pdu_ticketed",  "label": "Regulated / PDU-earning event", "note": "IBF/SILE CPD, professional CPD" }
  ],
  "needs": [
