{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "altru",
  "main": "src/worker.ts",
  "compatibility_date": "2026-04-12",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "altru",
      "database_id": "TODO_run_wrangler_d1_create_altru_THEN_PASTE_ID_HERE",
      "migrations_dir": "migrations"
    }
  ],

  // ── Cron Triggers ─────────────────────────────────────────────────────
  // All times are UTC. Singapore Standard Time (SST) = UTC+8.
  // Note: Workers Scheduled handler dispatches on event.cron.
  "triggers": {
    "crons": [
      "0 * * * *",    // Hourly:  auto-refund tick (expired gifts → refund)
      "0 1 * * *",    // 09:00 SGT daily: disbursement run (released gifts → PayNow)
      "0 2 1 * *",    // 10:00 SGT 1st of month: invoice generation + AI draft
      "0 3 * * *",    // 11:00 SGT daily: data retention sweep (sessions, OTPs)
      "0 4 * * *",    // 12:00 SGT daily: HitPay reconciliation report
      "0 5 * * *",    // 13:00 SGT daily: MAS sanctions list refresh (AI-assisted)
      "0 10 * * 1",   // 18:00 SGT every Monday: weekly AI compliance review
      "0 0 * * *"     // 08:00 SGT daily: DSR deadline checker (PDPA 30-day clock)
    ]
  },

  "vars": {
    "ENV": "dev",
    "PUBLIC_BASE_URL": "https://altru.asia",

    // ── Business logic ───────────────────────────────────────────────────
    "LARGE_GIFT_THRESHOLD_CENTS": "50000",   // S$500 — triggers sanctions check + step-up OTP
    "AUTO_REFUND_WINDOW_DAYS": "14",         // 14-day couple-authorisation window
    "PLATFORM_FEE_BPS": "500",              // 5% platform fee invoiced to charities

    // ── Compliance (public — non-sensitive) ───────────────────────────────
    "DPO_EMAIL": "dpo@altru.asia",
    // PSA_LICENCE_STATUS values: 'pending_legal_opinion' | 'exempt' | 'spi_licensed'
    // Update this after receiving legal opinion from payments counsel.
    "PSA_LICENCE_STATUS": "pending_legal_opinion",
    // AI_OPS_ENABLED: set to 'true' in prod once CLAUDE_API_KEY secret is configured.
    "AI_OPS_ENABLED": "false"

    // ── Secrets — set separately via: wrangler secret put <KEY> ─────────
    // RESEND_API_KEY
    // HITPAY_API_KEY
    // HITPAY_WEBHOOK_SECRET
    // NRIC_ENCRYPTION_KEY          — openssl rand -base64 32
    // SESSION_HMAC_SECRET          — openssl rand -hex 32
    // TWILIO_ACCOUNT_SID
    // TWILIO_AUTH_TOKEN
    // TWILIO_FROM_NUMBER           — E.164, e.g. +6581234567
    // CLAUDE_API_KEY               — Anthropic API key for AI ops agents
    // SANCTIONS_LIST_URL           — MAS designated-persons list URL
    // OPERATOR_NOTIFY_EMAIL        — Where compliance alerts are sent (your email)
  }
}
