  "rubrics": {
    "published_pricing_transparency": "0 = no price anywhere on site, full quote-on-brief. 1 = vague 'budget starts from' phrase, no per-pax. 2 = partial cost guide blog post but no SKU pricing. 3 = published per-pax band or per-station list price. 4 = published tier pricing with what-in/what-out. 5 = self-serve calculator with PAX \u00d7 tier \u00d7 add-ons returning a 24h budget band.",
    "ecosystem_manpower_depth": "0 = pure agency model, 100% subcontracted crew. 1 = retained freelance MC/photographer pool only. 2 = small in-house production crew (5-10 people). 3 = in-house creative + production crew but subcontracts promoters/security. 4 = in-house promoter pool + production crew, security via partner. 5 = in-house promoter pool + temp staffing arm + security arm + payroll/levy compliance under one group P&L.",
    "esg_certification": "0 = no ESG mention. 1 = sustainability claims, no audit. 2 = sustainability positioning + supplier checklists. 3 = single-event carbon report on request. 4 = ISO 20121 OR EcoVadis (any colour). 5 = ISO 20121 + EcoVadis Gold + carbon-tracking disclosed per event.",
    "ai_enabled_production": "0 = no AI features. 1 = generic 'AI-friendly' marketing copy. 2 = one AI tool (e.g. AI photobooth) bolted on. 3 = AI photobooth + RSVP triage assistant. 4 = AI photobooth + RSVP triage + post-event sentiment dashboard + attendee personalisation. 5 = full AI-event stack + IMDA pre-approved vendor (PSG/EDG GenAI grant track).",
    "hybrid_livestream_capability": "0 = no hybrid offering. 1 = basic Zoom relay subcontracted. 2 = single-camera livestream via partner. 3 = 2-camera livestream-ready in-house. 4 = 4-camera switcher feed + hybrid studio + captioning in-house. 5 = full broadcast-grade studio + AR/VR experiential + multi-room hybrid + 270-degree projection.",
    "govt_tender_credentials": "0 = no public-sector wins. 1 = single stat-board client. 2 = handful of public-sector references. 3 = multiple stat-board / healthcare cluster clients on case-study page. 4 = PCO award (Stella, ICCA) AND multi-year framework with stat board / cluster. 5 = Best PCO Asia (Stella) + multiple multi-year GeBIZ framework agreements + Minister-grade event experience.",
    "creative_theming_originality": "0 = template-only execution. 1 = generic theme library, no in-house design. 2 = in-house designer producing standard themes. 3 = in-house creative team + custom theme storyboards. 4 = bespoke creative with mood films + branded show-call scripts. 5 = proprietary game/show IP (e.g. Bumball) OR luxury creative pedigree with global awards.",
    "regional_rollout_reach": "0 = SG-only. 1 = SG + 1 SEA neighbour ad-hoc. 2 = SG + 2-3 SEA ad-hoc partners. 3 = formal SEA partner network across 4+ countries. 4 = own offices in 3+ SEA countries OR established regional fulfilment muscle. 5 = own offices in 6+ countries / 30+ offices globally with cross-border roll-out muscle."
  },
