# Copy to .env.local for local-only values; never commit .env.local.
# These two values get pasted into ESOP_CONFIG in each HTML page (browser-safe).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>

# Service-role key is used only by Edge Functions (admin-invite, verify-chain).
# Never expose to the browser. Set in Supabase dashboard, not here.
# SUPABASE_SERVICE_ROLE_KEY=
