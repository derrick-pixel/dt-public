# Cloudflare Pages — security headers
# SEC-P2 hardening: applied to every response from the static origin.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://*.supabase.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; img-src 'self' data: blob: https://*.supabase.co; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'

# Lock the assets and the PDF down a bit more.
/assets/*
  Cache-Control: public, max-age=300, must-revalidate
  X-Content-Type-Options: nosniff

/onboarding-guide.pdf
  Cache-Control: public, max-age=600
  Content-Disposition: inline; filename="Elitez-ESOP-Holder-Guide.pdf"
